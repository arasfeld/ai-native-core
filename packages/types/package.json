{
  "name": "@repo/types",
  "version": "0.1.0",
  "description": "Shared TypeScript types generated from the FastAPI OpenAPI spec",
  "private": true,
  "type": "module",
  "main": "./src/api.ts",
  "types": "./src/api.ts",
  "exports": {
    ".": "./src/api.ts"
  },
  "scripts": {
    "clean": "rm -rf dist node_modules",
    "format": "prettier --write .",
    "generate": "openapi-typescript http://localhost:8000/openapi.json -o src/api.ts",
    "generate:local": "openapi-typescript ./openapi.yaml -o src/api.ts"
  },
  "devDependencies": {
    "openapi-typescript": "^7.0.0"
  }
}
