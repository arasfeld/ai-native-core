{
  "name": "@repo/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist node_modules",
    "dev": "tsc --watch",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "migrate": "tsx src/migrate.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "pg": "^8.17.1",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.0.0",
    "typescript": "5.9.2"
  }
}
