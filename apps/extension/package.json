{
  "name": "extension",
  "version": "0.0.0",
  "private": true,
  "description": "AI Native Core browser extension",
  "type": "module",
  "scripts": {
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist node_modules",
    "dev": "wxt --port 5555",
    "dev:firefox": "wxt -b firefox",
    "postinstall": "wxt prepare",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox"
  },
  "dependencies": {
    "better-auth": "^1.5.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@wxt-dev/module-react": "^1.1.5",
    "typescript": "5.9.2",
    "wxt": "^0.20.18"
  }
}
