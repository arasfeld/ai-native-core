# AI Native Core — Environment Variables
# Copy to .env and fill in values. For local dev, LLM_PROVIDER=ollama requires no API keys.

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Choose: ollama | openai | anthropic | openrouter
LLM_PROVIDER=ollama

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenRouter (access to all major models, pay-per-use)
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Ollama (local inference, no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── Database ─────────────────────────────────────────────────────────────────
# Matches docker-compose.yml defaults
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aicore

# ─── API Server ───────────────────────────────────────────────────────────────
PORT=8000
CORS_ORIGIN=http://localhost:3000

# ─── Web App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Observability (optional) ─────────────────────────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-...
# LANGCHAIN_PROJECT=ai-native-core
