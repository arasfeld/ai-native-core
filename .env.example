# AI Native Core — Environment Variables
# Copy to .env and fill in values. For local dev, LLM_PROVIDER=ollama requires no API keys.

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Choose: ollama | openai | anthropic | openrouter
LLM_PROVIDER=ollama

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenRouter (access to all major models, pay-per-use)
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Ollama (local inference, no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2-vision    # Larger vision model (7.9GB, needs 11GB+ RAM)
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── Database ─────────────────────────────────────────────────────────────────
# Matches docker-compose.yml defaults
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aicore

# ─── Auth (required) ──────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=change-me-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000

# ─── API Server ───────────────────────────────────────────────────────────────
PORT=8000
CORS_ORIGIN=http://localhost:3000

# ─── Web App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
# URL the server uses when building Stripe redirect URLs
WEB_URL=http://localhost:3000
# Server-side URL used by Next.js API routes to call FastAPI
API_URL=http://localhost:8000
# Shared secret for Next.js → FastAPI internal requests
INTERNAL_SECRET=change-me-internal-secret

# ─── Redis (background jobs / ARQ worker) ─────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Stripe (optional — leave blank to disable billing) ──────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...

# ─── Email / Resend (optional — required for password reset emails) ───────────
# Get a free API key at https://resend.com
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=AI Native <noreply@yourdomain.com>

# ─── Observability (optional) ─────────────────────────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-...
# LANGCHAIN_PROJECT=ai-native-core
