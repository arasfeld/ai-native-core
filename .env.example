# AI Native Core — Environment Variables
# Copy to .env and fill in values. For local dev, LLM_PROVIDER=ollama requires no API keys.
# This file lists every variable the code reads. Uncommented vars are required for
# a basic local run; commented vars are optional (feature-gated or have safe defaults).

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Choose: ollama | openai | anthropic | openrouter
LLM_PROVIDER=ollama

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# Model overrides for the multi-modal endpoints (defaults shown):
# OPENAI_EMBED_MODEL=text-embedding-3-small
# OPENAI_IMAGE_MODEL=dall-e-3
# OPENAI_TRANSCRIBE_MODEL=whisper-1
# OPENAI_TTS_MODEL=tts-1

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_MAX_TOKENS=4096

# OpenRouter (access to all major models, pay-per-use)
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Ollama (local inference, no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2-vision    # Larger vision model (7.9GB, needs 11GB+ RAM)
OLLAMA_EMBED_MODEL=nomic-embed-text
# OLLAMA_TIMEOUT=120             # Request timeout in seconds (default 120)

# ─── Database ─────────────────────────────────────────────────────────────────
# Matches docker-compose.yml defaults
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aicore
# Guard for `pnpm db:reset` — must be "true" to allow dropping all tables
# ALLOW_DB_RESET=false

# ─── Auth (required) ──────────────────────────────────────────────────────────
# Used by better-auth (TypeScript). Must be at least 32 characters.
BETTER_AUTH_SECRET=change-me-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000

# ─── OAuth (optional — set BOTH id + secret of a provider to enable its login) ─
# Google: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GitHub: https://github.com/settings/developers
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ─── API Server ───────────────────────────────────────────────────────────────
PORT=8000
CORS_ORIGIN=http://localhost:3000
# Logging (FastAPI server)
# LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
# LOG_FORMAT=console             # console | json
# Per-session token cap (0 = unlimited)
# SESSION_TOKEN_BUDGET=100000
# Embedding vector dimension — must match your embed model + the pgvector column
# (nomic-embed-text=768, text-embedding-3-small=1536)
# EMBEDDING_DIM=768

# ─── Web App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
# The web app's own origin — used as the better-auth client baseURL
NEXT_PUBLIC_APP_URL=http://localhost:3000
# URL the server uses when building Stripe redirect URLs
WEB_URL=http://localhost:3000
# Server-side URL used by Next.js API routes to call FastAPI
API_URL=http://localhost:8000
# Shared secret for Next.js → FastAPI internal requests
INTERNAL_SECRET=change-me-internal-secret

# ─── Mobile App (Expo) ────────────────────────────────────────────────────────
# Base URL the mobile app calls. localhost works in the simulator; on a physical
# device use your machine's LAN IP (e.g. http://192.168.1.50:3000).
EXPO_PUBLIC_SERVER_URL=http://localhost:3000

# ─── Redis (background jobs / ARQ worker) ─────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Tools (optional) ─────────────────────────────────────────────────────────
# Tavily web-search tool — get a key at https://tavily.com
# TAVILY_API_KEY=tvly-...

# ─── Stripe (optional — leave blank to disable billing) ──────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...
# Used by the admin Analytics dashboard to estimate MRR (USD/month per Pro sub)
# PRO_PLAN_MONTHLY_USD=20

# ─── Email / Resend (optional — required for password reset emails) ───────────
# Get a free API key at https://resend.com
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=AI Native <noreply@yourdomain.com>

# ─── Observability (optional) ─────────────────────────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-...
# LANGCHAIN_PROJECT=ai-native-core

# Sentry — leave SENTRY_DSN blank to disable error reporting
# FastAPI server (Python):
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1
# SENTRY_RELEASE=0.1.0
# Next.js web (DSN is public; auth token is only needed for sourcemap uploads in CI):
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# Expo mobile:
# EXPO_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# EXPO_PUBLIC_SENTRY_ENVIRONMENT=development

# PostHog — leave the *_POSTHOG_KEY blank to disable product analytics
# Get a project API key (phc_...) at https://app.posthog.com. Self-hosting:
# point *_POSTHOG_HOST at your instance (default is https://us.i.posthog.com).
# Next.js web:
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Expo mobile:
# EXPO_PUBLIC_POSTHOG_KEY=phc_...
# EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Evaluation pipeline (optional — CI golden-answer evals) ──────────────────
# RUN_EVALS=true                 # Gates the eval suite (off by default)
# EVAL_DB_URL=postgresql://postgres:postgres@localhost:5432/aicore
# EVAL_JUDGE_PROVIDER=openai
# EVAL_JUDGE_MODEL=gpt-4o-mini
# DATASET_NAME=golden-qa
# PASS_THRESHOLD=0.75
